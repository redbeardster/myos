#!/usr/bin/expect -f
# QEMU regression for KSE-default scheduling.
# Usage: tools/qemu_kse_test.exp [path-to-iso]

set timeout 90
set iso [lindex $argv 0]
if {$iso eq ""} {
    set iso "build/myos.iso"
}

log_user 1
set logfile "/tmp/myos_kse_test.log"
log_file -noappend $logfile

spawn qemu-system-x86_64 -M q35 -m 256M -smp 8 -cdrom $iso -boot d -serial stdio -display none

expect {
    -re "MyOS>" { }
    timeout { puts "FAIL: boot timeout"; exit 1 }
}

send "exec hello.elf\r"
expect {
    -re "Hello" { puts "PASS: hello" }
    timeout { puts "FAIL: hello timeout"; exit 2 }
}
expect -re "MyOS>"

send "exec threads.elf\r"
expect {
    -re "main done" { puts "PASS: threads" }
    -re "#PF|panic|GPF" { puts "FAIL: threads crash"; exit 3 }
    timeout { puts "FAIL: threads timeout (main done never appeared)"; exit 4 }
}
expect -re "MyOS>"

send "ksebench 4 2000\r"
expect {
    -re "ksebench report|ksebench run" { puts "PASS: ksebench started" }
    -re "#PF|panic|create failed|exec failed" { puts "FAIL: ksebench crash"; exit 5 }
    timeout { puts "FAIL: ksebench start timeout"; exit 6 }
}
expect {
    -re "OK" { puts "PASS: ksebench OK" }
    -re "MISMATCH|FAIL" { puts "FAIL: ksebench mismatch"; exit 7 }
    timeout { puts "FAIL: ksebench report timeout"; exit 8 }
}
expect -re "MyOS>"

send "ksebench compare 4 5000\r"
expect {
    -re "ksebench compare" { puts "PASS: compare started" }
    -re "#PF|panic|create failed" { puts "FAIL: compare crash"; exit 9 }
    timeout { puts "FAIL: compare start timeout"; exit 10 }
}
expect {
    -re "winner:" { puts "PASS: compare winner" }
    -re "MISMATCH|FAIL" { puts "FAIL: compare mismatch"; exit 11 }
    timeout { puts "FAIL: compare report timeout"; exit 12 }
}
expect -re "MyOS>"

send "schedmode\r"
expect {
    -re "schedmode=1" { puts "PASS: default schedmode KSE" }
    -re "schedmode=0" { puts "WARN: schedmode still runner" }
    timeout { puts "FAIL: schedmode timeout"; exit 13 }
}
expect -re "MyOS>"

send "ps\r"
expect {
    -re "PID" { puts "PASS: ps" }
    timeout { puts "FAIL: ps timeout"; exit 14 }
}
expect -re "MyOS>"

send "exit\r"
expect eof
puts "ALL TESTS PASSED"
exit 0
